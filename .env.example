# Server
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Default user (change in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Model
DEFAULT_MODEL=./Qwen3-TTS-12Hz-1.7B-CustomVoice

# Generation limits
# Controls how long the generated audio can be per run.
# Higher = longer audio but more VRAM & time.
# At 12 Hz codec: tokens / 12 = seconds of audio
#   2048 = ~2:50 min / ~1800 chars  (default)
#   4096 = ~5:41 min / ~3700 chars
#   8192 = ~11:22 min / ~7400 chars  (model max)
MAX_NEW_TOKENS=2048

# Optimization
# USE_COMPILE: Uses torch.compile for 1.2x-1.5x speedup. First run will be slow (compilation),
# subsequent restarts load from the on-disk cache and start instantly.
USE_COMPILE=true
# TORCHINDUCTOR_CACHE_DIR: Directory where torch.compile stores compiled artifacts.
# Defaults to .torch_compile_cache/ next to app.py. Set to a fast SSD path for best results.
# TORCHINDUCTOR_CACHE_DIR=.torch_compile_cache
# LOAD_IN_4BIT: Reduces VRAM by 75% and improves speed on supported GPUs. 
# May slightly affect quality.
LOAD_IN_4BIT=false
# BATCH_SIZE: How many sentences to process in parallel. 
# Higher = better throughput (chars/sec) but more VRAM.
BATCH_SIZE=4